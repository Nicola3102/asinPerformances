MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=rug_user
MYSQL_PASSWORD=rug_password
MYSQL_DATABASE=rug
MYSQL_DB_NAME=asin_performances

# 在线库（执行 SQL 的数据源）
online_db_host=
online_db_port=3306
online_db_name=
online_db_user=
online_db_pwd=

# 定时同步（东八区每 N 小时执行一次 online_sync；后端进程需常驻）
enable_scheduled_sync=true
sync_interval_hours=2
sync_timezone=Asia/Shanghai
